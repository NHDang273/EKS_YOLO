# Copy this file to .env and update the values for your environment.

# Application Configuration
HOST=0.0.0.0
PORT=8000
MODEL_PATH=/models/best.pt
OUTPUT_PATH=/output
INFERENCE_DEVICE=cpu

# Kubernetes Runtime
POD_NAME=local
POD_NAMESPACE=default

# AWS and Deployment Configuration
AWS_REGION=ap-southeast-1
CLUSTER_NAME=yolo-inference-cluster
AWS_ACCOUNT_ID=
ECR_REPOSITORY=yolo-inference
ECR_URL=
S3_BUCKET=your-model-bucket
S3_MODEL_KEY=models/best.pt
EFS_ID=

# EKS Node Configuration
INFERENCE_NODE_INSTANCE_TYPE=t3.large
INFERENCE_NODE_MIN_SIZE=1
INFERENCE_NODE_MAX_SIZE=5
SYSTEM_NODE_INSTANCE_TYPE=t3.medium
SYSTEM_NODE_MIN_SIZE=2
SYSTEM_NODE_MAX_SIZE=4

# Kubernetes Resource Configuration
DEPLOYMENT_REPLICAS=2
CPU_REQUEST=1000m
CPU_LIMIT=2000m
MEMORY_REQUEST=2Gi
MEMORY_LIMIT=4Gi
